# Configuration Frontend
# En développement local, utilisez localhost:4000
# En Docker, utilisez http://backend:4000/api/v1
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Configuration Mode Développement
# Activez les données mockées si l'API backend n'est pas disponible
VITE_MOCK_DATA_ENABLED=true

# Configuration Service SMS
# Pour le développement, laissez désactivé. L'OTP sera affiché dans la console.
VITE_SMS_API_ENABLED=false
VITE_SMS_API_KEY=
VITE_SMS_API_URL=

# Configuration Authentification Google
# Pour le développement, laissez désactivé. Un utilisateur fictif sera créé.
VITE_GOOGLE_AUTH_ENABLED=false
VITE_GOOGLE_CLIENT_ID=

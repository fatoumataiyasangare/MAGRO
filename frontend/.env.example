# ─── API Backend ─────────────────────────────────────────────────
# URL de base de l'API. En développement local, utilisez localhost.
# En Docker, utilisez le nom du service backend.
VITE_API_BASE_URL=http://localhost:4000/api/v1

# ─── Mode Développement ──────────────────────────────────────────
# Activez les données mockées si le backend n'est pas disponible.
VITE_MOCK_DATA_ENABLED=false

# ─── Service SMS ─────────────────────────────────────────────────
# Mettre à true pour envoyer de vrais SMS. Laisser false en dev
# (le code OTP s'affichera dans la console du backend).
VITE_SMS_API_ENABLED=false
VITE_SMS_API_KEY=
VITE_SMS_API_URL=

# ─── Authentification Google ──────────────────────────────────────
# Obtenir un Client ID sur https://console.cloud.google.com/
VITE_GOOGLE_AUTH_ENABLED=false
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  phone                   String                   @unique
  name                    String
  email                   String?                  @unique
  passwordHash            String
  role                    UserRole                 @default(BUYER)
  buyerType               BuyerType?
  region                  String
  isVerified              Boolean                  @default(false)
  isPremium               Boolean                  @default(false)
  rating                  Decimal                  @default(0) @db.Decimal(2, 1)
  deliveryRate            Decimal                  @default(100) @db.Decimal(5, 2)
  disputeCount30d         Int                      @default(0)
  suspensionUntil         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  avatarUrl               String?
  auditLogs               AuditLog[]
  alerts                  AvailabilityAlert[]
  expertCertifications    Certification[]          @relation("ExpertCertifications")
  farmerCertifications    Certification[]          @relation("FarmerCertifications")
  financedCertifications  Certification[]          @relation("FinancedCertifications")
  conversationsAsP1       Conversation[]           @relation("ConvParticipant1")
  conversationsAsP2       Conversation[]           @relation("ConvParticipant2")
  cooperativeMembers      CooperativeMember[]      @relation("CooperativeRelation")
  memberOfCooperatives    CooperativeMember[]      @relation("MemberRelation")
  disputesAssigned        Dispute[]                @relation("DisputesAssigned")
  disputesDecided         Dispute[]                @relation("DisputesDecided")
  disputesOpened          Dispute[]                @relation("DisputesOpened")
  favorites               Favorite[]
  listings                Listing[]
  messagesSent            Message[]                @relation("MessageSender")
  orders                  Order[]                  @relation("BuyerOrders")
  refreshTokens           RefreshToken[]
  buyerContracts          SeasonalContract[]       @relation("BuyerContracts")
  farmerContracts         SeasonalContract[]       @relation("FarmerContracts")
  trustedPairsBuyer       TrustedPair[]            @relation("TrustedPairsBuyer")
  trustedPairsFarmer      TrustedPair[]            @relation("TrustedPairsFarmer")
  reviewedVerifications   VerificationRequest[]    @relation("ReviewerVerifications")
  verificationRequests    VerificationRequest[]    @relation("UserVerifications")
  accountDeletionRequests AccountDeletionRequest[]
}

model RefreshToken {
  id                String    @id @default(uuid())
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  userAgent         String?
  ipAddress         String?
  userId            String
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model Listing {
  id                String     @id @default(uuid())
  title             String
  description       String
  price             Int
  quantity          Int
  quantityRemaining Int        @default(0)
  unit              String     @default("kg")
  region            String
  image             String
  imageUrls         String[]
  farmerId          String
  certificationId   String?
  videoUrl          String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  favorites         Favorite[]
  farmer            User       @relation(fields: [farmerId], references: [id])
  orders            Order[]

  @@index([farmerId])
  @@index([region])
  @@index([createdAt])
}

model Certification {
  id                String              @id @default(uuid())
  farmerId          String
  expertId          String
  cropName          String
  score             Int
  badgeLevel        BadgeLevel
  criteriaDetail    Json
  reportUrl         String
  validFrom         DateTime
  validTo           DateTime
  status            CertificationStatus @default(ACTIVE)
  financedByBuyerId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  expert            User                @relation("ExpertCertifications", fields: [expertId], references: [id])
  farmer            User                @relation("FarmerCertifications", fields: [farmerId], references: [id])
  financedByBuyer   User?               @relation("FinancedCertifications", fields: [financedByBuyerId], references: [id])
}

model Order {
  id                    String                 @id @default(uuid())
  buyerId               String
  listingId             String
  quantity              Int
  totalPrice            Int
  depositAmount         Int?
  depositRequired       Boolean                @default(false)
  riskScore             Int                    @default(0)
  status                String                 @default("EN_ATTENTE")
  paymentStatus         String                 @default("UNPAID")
  deliveryDate          DateTime?
  isRecurring           Boolean                @default(false)
  recurringInterval     String?
  confirmedAt           DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  disputes              Dispute[]
  buyer                 User                   @relation("BuyerOrders", fields: [buyerId], references: [id])
  listing               Listing                @relation(fields: [listingId], references: [id])
  transportNegotiations TransportNegotiation[]

  @@index([buyerId])
  @@index([listingId])
  @@index([status])
}

model Dispute {
  id             String           @id @default(uuid())
  orderId        String
  openedBy       String
  assignedTo     String?
  reason         String
  status         DisputeStatus    @default(NEW)
  evidenceFarmer Json?
  evidenceBuyer  Json?
  adminDecision  DisputeDecision?
  splitRatio     Decimal?         @db.Decimal(4, 2)
  decisionNote   String?
  decidedBy      String?
  resolvedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assignedToUser User?            @relation("DisputesAssigned", fields: [assignedTo], references: [id])
  decidedByUser  User?            @relation("DisputesDecided", fields: [decidedBy], references: [id])
  openedByUser   User             @relation("DisputesOpened", fields: [openedBy], references: [id])
  order          Order            @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([openedBy])
  @@index([status])
}

model VerificationRequest {
  id              String             @id @default(uuid())
  userId          String
  documents       Json
  status          VerificationStatus @default(PENDING)
  reviewedBy      String?
  rejectionReason String?
  createdAt       DateTime           @default(now())
  reviewedAt      DateTime?
  reviewedByUser  User?              @relation("ReviewerVerifications", fields: [reviewedBy], references: [id])
  user            User               @relation("UserVerifications", fields: [userId], references: [id])
}

model AvailabilityAlert {
  id                 String    @id @default(uuid())
  buyerId            String
  cropName           String
  region             String?
  notifiedPremiumAt  DateTime?
  notifiedStandardAt DateTime?
  createdAt          DateTime  @default(now())
  buyer              User      @relation(fields: [buyerId], references: [id])
}

model SeasonalContract {
  id               String                 @id @default(uuid())
  buyerId          String
  farmerId         String
  cropName         String
  totalQuantityKg  Int
  pricePerKg       Int
  seasonStart      DateTime
  seasonEnd        DateTime
  deliverySchedule Json
  status           SeasonalContractStatus @default(PENDING)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  buyer            User                   @relation("BuyerContracts", fields: [buyerId], references: [id])
  farmer           User                   @relation("FarmerContracts", fields: [farmerId], references: [id])
}

model TrustedPair {
  id          String   @id @default(uuid())
  farmerId    String
  buyerId     String
  qualifiedAt DateTime @default(now())
  buyer       User     @relation("TrustedPairsBuyer", fields: [buyerId], references: [id])
  farmer      User     @relation("TrustedPairsFarmer", fields: [farmerId], references: [id])
}

model CooperativeMember {
  id            String   @id @default(uuid())
  cooperativeId String
  memberId      String
  joinedAt      DateTime @default(now())
  cooperative   User     @relation("CooperativeRelation", fields: [cooperativeId], references: [id])
  member        User     @relation("MemberRelation", fields: [memberId], references: [id])
}

model LoginOtp {
  id        String   @id @default(uuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model InstitutionalApiKey {
  id          String    @id @default(uuid())
  partnerName String
  apiKeyHash  String
  quotaPerDay Int
  isActive    Boolean   @default(true)
  createdBy   String
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model TransportNegotiation {
  id               String   @id @default(uuid())
  orderId          String
  buyerId          String
  transporterName  String
  transporterPhone String
  proposedPrice    Int
  status           String   @default("PENDING")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  order            Order    @relation(fields: [orderId], references: [id])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Conversation {
  id             String    @id @default(uuid())
  participant1Id String
  participant2Id String
  lastMessageAt  DateTime?
  createdAt      DateTime  @default(now())
  participant1   User      @relation("ConvParticipant1", fields: [participant1Id], references: [id])
  participant2   User      @relation("ConvParticipant2", fields: [participant2Id], references: [id])
  messages       Message[]

  @@unique([participant1Id, participant2Id])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

enum UserRole {
  BUYER
  FARMER
  COOPERATIVE
  EXPERT
  MODERATOR
  ANALYST
  SUPER_ADMIN
}

enum BuyerType {
  INDIVIDUAL
  TRADER
  RESTAURANT
  INSTITUTION
  INDUSTRY
}

enum BadgeLevel {
  GOLD
  SILVER
}

enum CertificationStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum DisputeStatus {
  NEW
  IN_REVIEW
  AWAITING_EVIDENCE
  PENDING_REINSPECTION
  RESOLVED
}

enum DisputeDecision {
  FARMER_WINS
  BUYER_WINS
  SPLIT
  REINSPECTION
  PARTIAL_REFUND
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum SeasonalContractStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model AccountDeletionRequest {
  id        String             @id @default(uuid())
  userId    String             @unique
  reason    String?
  status    VerificationStatus @default(PENDING)
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id])
}

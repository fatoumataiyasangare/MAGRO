# Configuration Base de Données PostgreSQL
# En développement local: postgresql://magro_user:magro_password@localhost:5432/magro
# En Docker: postgresql://magro_user:magro_password@postgres:5432/magro
DATABASE_URL=postgresql://magro_user:magro_password@localhost:5432/magro

# Configuration Serveur
PORT=4000
NODE_ENV=development

# Configuration JWT
# Générez un secret sécurisé avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=magro-dev-secret-key-change-in-production-12345

# Configuration CORS
# Origines autorisées pour les requêtes frontend (séparées par des virgules)
# En développement local: http://localhost:5173
# En Docker: http://localhost
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000

# Configuration Service SMS
# Pour le développement, laissez désactivé. L'OTP sera affiché dans la console.
SMS_API_ENABLED=false
SMS_API_KEY=
SMS_API_URL=
SMS_SENDER_ID=MAGRO

# Fournisseurs SMS supportés (à configurer lors de l'intégration réelle):
# - Twilio: https://www.twilio.com
# - Africa's Talking: https://www.africastalking.com
# - Orange SMS: https://www.orange.com
# - MTN SMS: https://www.mtn.com

# Configuration Authentification Google (optionnel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
